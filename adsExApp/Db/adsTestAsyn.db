# fTestArray: waveform Input

record(waveform,"$(P)GetFTestArray"){
    field(PINI, "1")
    field(TSE,  "-2")
    field(DTYP, "asynFloat64ArrayIn")
    field(INP,  "@asyn($(PORT),0,1)ADSPORT=$(ADSPORT=851)/Main.fTestArray?")
    field(NELM, "100")
    field(SCAN, "I/O Intr")
    field(FTVL, "DOUBLE")
}

